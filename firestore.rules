rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isValidDNI(dni) {
      return dni.matches('^[0-9]{7,8}$');
    }
    
    function isEventoActivo(eventoId) {
      return get(/databases/$(database)/documents/eventos/$(eventoId)).data.activo == true;
    }
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Colección de configuración visual (estilos personalizables)
    match /configuracion/{configId} {
      // Permitir lectura pública de la configuración visual
      // Esto permite que cualquier usuario vea los estilos aplicados
      allow read: if true;
      
      // Solo admin autenticado puede modificar estilos
      allow create, update: if isAuthenticated() 
        && configId == 'estilos'
        && request.resource.data.keys().hasAll(['primaryColor'])
        && request.resource.data.primaryColor is string;
      
      // No permitir eliminación de configuración de estilos
      allow delete: if false;
    }
    
    // Colección de eventos
    match /eventos/{eventoId} {
      // Permitir lectura pública de eventos activos (para obtener el evento activo)
      // Esto permite tanto get() individual como list() con query
      allow read: if resource == null || resource.data.activo == true;
      
      // Admin autenticado puede hacer todo
      allow read, write: if isAuthenticated();
      
      // Permitir a usuarios no autenticados incrementar SOLO el contador totalRegistros
      // cuando el evento está activo (necesario para el flujo de registro público)
      allow update: if resource != null
        && resource.data.activo == true
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalRegistros']);
      
      // Subcolección de registros por evento
      match /registros/{dni} {
        // Permitir crear registro si:
        // 1. El evento está activo
        // 2. El DNI es válido (7-8 dígitos)
        // 3. El DNI del documento coincide con el path (evita manipulación)
        allow create: if isEventoActivo(eventoId)
          && isValidDNI(dni)
          && request.resource.data.dni == dni
          && request.resource.data.keys().hasAll(['dni', 'nombreCompleto', 'fechaNacimiento', 'email', 'telefono']);
        
        // Permitir lectura pública de un DNI específico (para verificar duplicados)
        // No se requiere que el evento esté activo para leer: es solo verificación de duplicados
        // y no representa riesgo de seguridad. Eliminar isEventoActivo() aquí ahorra
        // 1 lectura oculta de Firestore por cada intento de registro.
        allow read: if isValidDNI(dni);
        
        // Admin autenticado puede leer todo con collectionGroup
        allow list: if isAuthenticated();
        
        // No permitir actualización ni eliminación (registros inmutables)
        allow update, delete: if false;
      }
    }
  }
}
